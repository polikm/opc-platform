# ============================================================
# OPC智能体平台 - 环境变量配置示例
# ============================================================
# 复制此文件为 .env 并根据实际情况修改配置
#   cp .env.example .env
# ============================================================

# ============================================================
# 通用配置
# ============================================================
NODE_ENV=development

# ============================================================
# PostgreSQL 主数据库配置
# ============================================================
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=opc_platform

# ============================================================
# Redis 缓存配置
# ============================================================
REDIS_PORT=6379
REDIS_PASSWORD=redis123

# ============================================================
# MinIO 对象存储配置
# ============================================================
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_BUCKET=opc-uploads

# ============================================================
# API 网关配置（NestJS）
# ============================================================
API_GATEWAY_PORT=3000
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d
CORS_ORIGIN=http://localhost:3001
SWAGGER_TITLE=OPC智能体系统 API
SWAGGER_DESCRIPTION=OPC智能体系统业务API网关文档
SWAGGER_VERSION=1.0
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# ============================================================
# AI 服务配置（FastAPI）
# ============================================================
AI_SERVICE_PORT=8000
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

# ============================================================
# Web 前端配置（Next.js）
# ============================================================
WEB_PORT=3001
NEXT_PUBLIC_API_URL=http://localhost:3000
NEXT_PUBLIC_AI_URL=http://localhost:8000
NEXT_PUBLIC_DIFY_URL=http://localhost:3002

# ============================================================
# Nginx 配置
# ============================================================
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# ============================================================
# Dify AI 平台配置
# ============================================================

# Dify 服务端口
DIFY_API_PORT=5001
DIFY_WEB_PORT=3002

# Dify 数据库配置（独立于主数据库）
DIFY_DB_PASSWORD=difyai123456
DIFY_DB_DATABASE=dify

# Dify Redis配置（独立于主Redis）
DIFY_REDIS_PASSWORD=difyai123456

# Dify 安全密钥（生产环境请使用 openssl rand -base64 42 生成）
DIFY_SECRET_KEY=sk-opc-dify-dev-secret-key-change-me

# Dify 沙箱API密钥
DIFY_SANDBOX_API_KEY=dify-sandbox

# Dify 控制台URL（留空则使用默认值）
DIFY_CONSOLE_WEB_URL=
DIFY_CONSOLE_API_URL=
DIFY_SERVICE_API_URL=
DIFY_APP_WEB_URL=
DIFY_FILES_URL=

# Dify API密钥（用于OPC平台与Dify集成）
DIFY_API_KEY=
