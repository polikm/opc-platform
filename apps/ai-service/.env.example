# ============================================================
# OPC AI Service 环境变量配置
# ============================================================

# ---- 应用配置 ----
APP_NAME=opc-ai-service
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# ---- Dify 配置 ----
DIFY_API_URL=http://localhost:5001/v1
DIFY_API_KEY=app-your-dify-api-key

# ---- 数据库配置 ----
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/opc_ai
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ---- Redis 配置 ----
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=3600

# ---- JWT 认证配置 ----
JWT_SECRET=your-jwt-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ---- LLM 模型配置 ----
LLM_DEFAULT_MODEL=gpt-4o
LLM_API_KEY=sk-your-openai-api-key
LLM_BASE_URL=https://api.openai.com/v1
LLM_FALLBACK_MODEL=gpt-4o-mini
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.7

# ---- Token 配额 ----
TOKEN_QUOTA_PER_USER=1000000
TOKEN_QUOTA_RESET_DAYS=30

# ---- CORS 配置 ----
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ---- MCP 配置 ----
MCP_SERVER_URL=http://localhost:8001
MCP_TIMEOUT=30

# ---- 文件上传配置 ----
MAX_UPLOAD_SIZE=52428800
UPLOAD_DIR=/tmp/uploads
