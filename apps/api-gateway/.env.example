# ============================================
# OPC智能体系统 - API网关 环境变量配置
# ============================================

# 服务配置
NODE_ENV=development
PORT=3000
API_PREFIX=api

# 数据库配置 (PostgreSQL)
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=opc_platform

# JWT配置
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# CORS配置
CORS_ORIGIN=http://localhost:3001

# Swagger配置
SWAGGER_TITLE=OPC智能体系统 API
SWAGGER_DESCRIPTION=OPC智能体系统业务API网关文档
SWAGGER_VERSION=1.0

# 限流配置
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# Redis配置 (可选)
REDIS_HOST=localhost
REDIS_PORT=6379
